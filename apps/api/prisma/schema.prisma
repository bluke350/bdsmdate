generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model Profile {
    id                   String    @id
    displayName          String
    age                  Int
    role                 String
    bio                  String
    verified             Boolean
    intent               String?
    state                String?
    zip                  String?
    experienceLevel      String?
    aftercare            String?
    sceneTypes           String?
    hardLimits           String?
    kinkTags             String?
    safeword             String?
    boundaries           String?
    relationshipStyle    String?
    availability         String?
    playLocation         String?
    aftercarePreferences String?
    aftercareNotes       String?
    softLimits           String?
    limitsNotes          String?
    lastActiveAt         DateTime?
    boostedUntil         DateTime?
    photoKey             String?
    photoKeys            String?
    createdAt            DateTime  @default(now())
    updatedAt            DateTime  @updatedAt
}
